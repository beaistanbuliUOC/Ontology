        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date when incident happened</rdfs:comment>
        <rdfs:label xml:lang="en">Event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#imdrf_code -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#imdrf_code">
