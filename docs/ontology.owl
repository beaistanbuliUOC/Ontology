    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskCategory -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskCategory">
        <rdfs:comment xml:lang="en">Risk category class</rdfs:comment>
        <rdfs:label xml:lang="en">Risk category</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass">
        <rdfs:comment xml:lang="en">Class of risk by MDR</rdfs:comment>
        <rdfs:label xml:lang="en">Risk class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType">
        <rdfs:comment xml:lang="en">Risk type class</rdfs:comment>
        <rdfs:label xml:lang="en">Risk type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SafetyAlert -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#UserNotice"/>
        <rdfs:comment>It is a mandatory communication sent by a medical device manufacturer to users (hospitals, doctors, patients) to prevent or reduce the risk of a serious incident with a device that is already on the market</rdfs:comment>
        <rdfs:label xml:lang="en">Safety alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse"/>
        <rdfs:comment xml:lang="en">It is an in vitro diagnostic medical device intended by the manufacturer for use by laypersons in a home environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Self test</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Serious -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Serious">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#IncidentType"/>
        <rdfs:comment xml:lang="en">It is defined as any incident involving a device that directly or indirectly led, might have led, or might lead to the death of a patient/user, a serious deterioration in health (temporary/permanent), or a serious public health threat. It includes malfunctions, performance issues, and use errors.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType"/>
        <rdfs:comment xml:lang="en">It is defined as a device intended to be used on one individual patient during a single procedure and then discarded. They are not intended to be reprocessed or reused.</rdfs:comment>
        <rdfs:label xml:lang="en">Single use</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Software -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Software">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType"/>
        <rdfs:comment xml:lang="en">Risks caused by software</rdfs:comment>
        <rdfs:label xml:lang="en">Software</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Swiss authority</rdfs:comment>
        <rdfs:label xml:lang="en">Swissmedic</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#UserNotice -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#UserNotice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType"/>
        <rdfs:comment xml:lang="en">It is an official communication from a manufacturer to users informing them of a safety risk with a medical device and providing instructions to prevent harm.</rdfs:comment>
        <rdfs:label xml:lang="en">User notice</rdfs:label>
    </owl:Class>
    


