        <clasificacion_MDR_IVDR:severity>Critical</clasificacion_MDR_IVDR:severity>
        <rdfs:comment xml:lang="en">First risk</rdfs:comment>
        <rdfs:label xml:lang="en">Risk 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RSK-003 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RSK-003">
        <rdf:type rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk"/>
        <rdf:type>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasAffectedDeviceType"/>
