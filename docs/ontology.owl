<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/bea/ontologies/2026/clasificacion_MDR_IVDR#"
     xml:base="http://www.semanticweb.org/bea/ontologies/2026/clasificacion_MDR_IVDR"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:schema="http://schema.org/"
     xmlns:clasificacion_MDR_IVDR="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/bea/ontologies/2026/clasificacion_MDR_IVDR">
        <dc:creator>Beatriz Istanbouli Sahelieh</dc:creator>
        <dc:description>Description: An ontology designed to map the various high-risk medical devices, as well as in vitro diagnostic devices, in accordance with European regulations under the MDR (medical devices in classes I, IIa, IIb, III) and IVDR (in vitro diagnostic devices in classes A, B, C, D), linking devices to their manufacturers, risks, reported incidents, and corrective actions.
We do this using the LOT methodology.
Purpose and use case: to standardize and enable interoperability of information from various sources, facilitating market surveillance and, above all, regulatory compliance. With this ontology, we perform logical inferences to automatically identify risk levels or dependencies between incidents and safety actions. It can be useful for a health authority that wants to consult the safety history of a specific device, check risks, the corrective actions taken, and other information about the device.</dc:description>
        <dc:rights>No license</dc:rights>
        <dc:title>Classification of medical devices and in vitro diagnostic devices according to the European MDR and IVDR regulations</dc:title>
        <owl:versionInfo>V1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/rights -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/rights"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#sameAs -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#sameAs"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#authorizedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#authorizedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority"/>
        <rdfs:comment>Relation between a Manufacturer and the corresponding competent authority</rdfs:comment>
        <rdfs:label>Authorized by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasActionStatus -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasActionStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus"/>
        <rdfs:comment>Status of a corrective aciton</rdfs:comment>
        <rdfs:label>Has action status?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasActionType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasActionType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType"/>
        <rdfs:comment>Type of corrective action applied</rdfs:comment>
        <rdfs:label>Has action type?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasAffectedDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasAffectedDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType"/>
        <rdfs:comment>Type of affected device in a specific risk</rdfs:comment>
        <rdfs:label>Has affected device type?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasDevice">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:comment>Relation between the incident and the medical device</rdfs:comment>
        <rdfs:label>has device?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType"/>
        <rdfs:comment>Type of medical device</rdfs:comment>
        <rdfs:label>has device type?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasIncident -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasIncident">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:comment>Relation between the corrective action and its incident</rdfs:comment>
        <rdfs:label>has incident?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasIncidentType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasIncidentType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#IncidentType"/>
        <rdfs:comment>Type of incident</rdfs:comment>
        <rdfs:label>has incident type?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Manufacturer"/>
        <rdfs:comment>Relation between a device and its incident</rdfs:comment>
        <rdfs:label>has manufacturer?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRisk -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRisk">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk"/>
        <rdfs:comment>Relation between incident and a risk</rdfs:comment>
        <rdfs:label>has risk?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskCategory -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskCategory">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskCategory"/>
        <rdfs:comment>Relation between risk and its category</rdfs:comment>
        <rdfs:label>has risk category?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass"/>
        <rdfs:comment>Relation between the device and its risk class (important)</rdfs:comment>
        <rdfs:label>has risk class?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskType -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType"/>
        <rdfs:comment>Type of risks</rdfs:comment>
        <rdfs:label>has risk type?</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#reportingBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#reportingBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Manufacturer"/>
        <rdfs:comment>Relation between incident and its manufacturer</rdfs:comment>
        <rdfs:label>Reporting by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://schema.org/description -->


    <owl:DatatypeProperty rdf:about="http://schema.org/description">
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/description"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>Description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/email -->


    <owl:DatatypeProperty rdf:about="http://schema.org/email">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Manufacturer"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/email"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Email of the manufacturer</rdfs:comment>
        <rdfs:label>email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/location -->


    <owl:DatatypeProperty rdf:about="http://schema.org/location">
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/location"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>Location</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/name -->


    <owl:DatatypeProperty rdf:about="http://schema.org/name">
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/name"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>Name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#action_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#action_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#action_date"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date when corrective action began</rdfs:comment>
        <rdfs:label>Action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#authorization_number -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#authorization_number">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Manufacturer"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#authorization_number"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Auth number of the manufacturer</rdfs:comment>
        <rdfs:label>Auth number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#closure_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#closure_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#closure_date"/>
                <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date when corretive actions end</rdfs:comment>
        <rdfs:label>Closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#corrective_action_taken -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#corrective_action_taken">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#corrective_action_taken"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label>Corrective action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#detection_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#detection_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#detection_date"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date when incident was detected</rdfs:comment>
        <rdfs:label>Detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#devices_affected -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#devices_affected">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#devices_affected"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Number of affected devices</rdfs:comment>
        <rdfs:label>Devices affected</rdfs:label>
