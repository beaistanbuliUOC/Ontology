    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#AFMPS -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#AFMPS">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ANSM"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#BfArM"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#HPRA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MHRA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MPA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RIVM"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic"/>
        <rdfs:comment xml:lang="fr">Agence Fédérale des Médicaments et des Produits de Santé</rdfs:comment>
        <rdfs:label>AFMPS</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ANSM -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ANSM">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#BfArM"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#HPRA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MHRA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MPA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RIVM"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic"/>
        <rdfs:comment xml:lang="fr-be">Agence Nationale de Sécurité du Médicament et des Produits de Santé</rdfs:comment>
        <rdfs:label>ANSM</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus">
        <rdfs:comment xml:lang="en">Corrective action status</rdfs:comment>
        <rdfs:label xml:lang="en">Action status</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType">
        <rdfs:comment xml:lang="en">Type of corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">Action type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Active -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Active">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActiveImplant"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Implantable"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InVitroDiagnostic"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse"/>
        <rdfs:comment>It is any medical device that relies on a source of energy other than that generated directly by the human body or gravity.</rdfs:comment>
        <rdfs:label xml:lang="en">Active</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActiveImplant -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Implantable"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InVitroDiagnostic"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse"/>
        <rdfs:comment xml:lang="en">Any device relying on a power source other than human energy or gravity, intended to be totally or partially introduced into the body (or replacing an eye surface) via clinical intervention and intended to remain after the procedure</rdfs:comment>
        <rdfs:label xml:lang="en">Active implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#BfArM -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#BfArM">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#HPRA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MHRA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MPA"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RIVM"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic"/>
        <rdfs:comment xml:lang="de">Bundesinstitut für Arzneimittel und Medizinprodukte</rdfs:comment>
        <rdfs:label>BfArM</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassI -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassI">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIII"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIa"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb"/>
        <rdfs:comment xml:lang="en">Devices with minimal risk to patient safety, such as non-electronic walking aids, bandages, or simple surgical instruments.</rdfs:comment>
        <rdfs:label xml:lang="en">Class I</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIII -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIa"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb"/>
        <rdfs:comment xml:lang="en">Devices with the highest risk profile, which are vital for supporting life, have direct contact with the heart/central circulatory system, or are permanently implanted, such as cardiac pacemakers, heart valves, and breast implants.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIa -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb"/>
        <rdfs:comment xml:lang="en">Devices with a moderate risk level, often used for short-term, non-critical, or diagnostic purposes, such as hearing aids, ultrasound equipment, or standard catheters.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass"/>
        <rdfs:comment xml:lang="en">Devices that pose significant risk, often including active devices meant for monitoring or administering substances, or long-term implants, such as ventilators, infusion pumps, or bone fixation devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Closed -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Closed">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Open"/>
        <rdfs:comment xml:lang="en">Corrective Action is closed</rdfs:comment>
        <rdfs:label xml:lang="en">Closed</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority">
        <rdfs:comment xml:lang="en">Class of Competent Authorities</rdfs:comment>
        <rdfs:label xml:lang="en">Competent authority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Contamination -->


    <owl:Class rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Contamination">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType"/>
