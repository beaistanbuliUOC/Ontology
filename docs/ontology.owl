        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">IMDRF code</rdfs:comment>
        <rdfs:label xml:lang="en">IMDRF</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#intended_purpose -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#intended_purpose">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Intented purpose of a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_active -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_active">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if the medical is active, false if it is not.</rdfs:comment>
        <rdfs:label xml:lang="en">Is active?</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_implantable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_implantable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if the medical is implantable, false if it is not.</rdfs:comment>
        <rdfs:label xml:lang="en">Is implantable?</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_ivd -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_ivd">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if the medical is ivd, false if it is not.</rdfs:comment>
        <rdfs:label xml:lang="en">Is ivd?</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_reusable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_reusable">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">True if the medical is reusable, false if it is not.</rdfs:comment>
        <rdfs:label xml:lang="en">Is reusable?</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#outcome -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#outcome">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Impact of the incident</rdfs:comment>
        <rdfs:label xml:lang="en">Outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#patient_age -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#patient_age">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Age of the registered patient</rdfs:comment>
        <rdfs:label xml:lang="en">Patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#patient_sex -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#patient_sex">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Gender of the registered patient</rdfs:comment>
        <rdfs:label xml:lang="en">Patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#probability -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#probability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">It can take the next values: high, medium or low</rdfs:comment>
        <rdfs:label xml:lang="en">Probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#regulatory_framework -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#regulatory_framework">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">MDR or IVDR, depending on the type of device</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory framework</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#report_date -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#report_date">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Report date of an incident</rdfs:comment>
        <rdfs:label xml:lang="en">Report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#scope -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#scope">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Actions taken to eliminate the root cause of the incident</rdfs:comment>
        <rdfs:label xml:lang="en">Scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#severity -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#severity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Level of severity of a risk. 
Values: critical, serious, moderate.</rdfs:comment>
        <rdfs:label xml:lang="en">Severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#udi_di -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#udi_di">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of medical devices</rdfs:comment>
        <rdfs:label xml:lang="en">UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


