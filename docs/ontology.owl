    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DEV-001 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DEV-001">
        <rdf:type rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device"/>
        <rdf:type>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasDeviceType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive"/>
            </owl:Restriction>
        </rdf:type>
        <rdf:type>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskClass"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIII"/>
            </owl:Restriction>
        </rdf:type>
        <rdf:type>
            <owl:Restriction>
