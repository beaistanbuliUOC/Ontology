    <!-- http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RSK-001 -->


    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RSK-001">
