  } ]
}, {
  "@id" : "http://www.semanticweb.org/bea/ontologies/2026/clasificacion_MDR_IVDR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/elements/1.1/creator" : [ {
    "@value" : "Beatriz Istanbouli Sahelieh"
  } ],
  "http://purl.org/dc/elements/1.1/description" : [ {
    "@value" : "Description: An ontology designed to map the various high-risk medical devices, as well as in vitro diagnostic devices, in accordance with European regulations under the MDR (medical devices in classes I, IIa, IIb, III) and IVDR (in vitro diagnostic devices in classes A, B, C, D), linking devices to their manufacturers, risks, reported incidents, and corrective actions.\nWe do this using the LOT methodology.\nPurpose and use case: to standardize and enable interoperability of information from various sources, facilitating market surveillance and, above all, regulatory compliance. With this ontology, we perform logical inferences to automatically identify risk levels or dependencies between incidents and safety actions. It can be useful for a health authority that wants to consult the safety history of a specific device, check risks, the corrective actions taken, and other information about the device."
  } ],
  "http://purl.org/dc/elements/1.1/rights" : [ {
    "@value" : "No license"
  } ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@value" : "Classification of medical devices and in vitro diagnostic devices according to the European MDR and IVDR regulations"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "V1.0"
  } ]
}, {
  "@id" : "http://www.w3.org/2000/01/rdf-schema#sameAs",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/2001/XMLSchema#date",
  "@type" : [ "http://www.w3.org/2000/01/rdf-schema#Datatype" ]
}, {
  "@id" : "urn:swrl:var#d",
  "@type" : [ "http://www.w3.org/2003/11/swrl#Variable" ]
} ]