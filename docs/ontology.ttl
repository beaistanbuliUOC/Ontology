@prefix : <http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#> .

<http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR> rdf:type owl:Ontology ;
                                                                         owl:versionIRI <http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR/1.0.0> ;
                                                                         <http://purl.org/dc/terms/bibliographicCitation> "Beatriz I. S. - Classification of medical devices and in vitro diagnostic devices according to the European MDR and IVDR regulations"@en ;
                                                                         <http://purl.org/dc/terms/created> "2026-04-20"@en ;
                                                                         <http://purl.org/dc/terms/creator> "Beatriz Istanbouli Sahelieh"@en ;
                                                                         <http://purl.org/dc/terms/description> """An ontology designed to map the various high-risk medical devices, as well as in vitro diagnostic devices, in accordance with European regulations under the MDR and IVDR, linking devices to their manufacturers, risks, reported incidents, and corrective actions.

We do this using the LOT methodology.

Purpose and use case: to standardize and enable interoperability of information from various sources, facilitating market surveillance and, above all, regulatory compliance. With this ontology, we perform logical inferences to automatically identify risk levels or dependencies between incidents and safety actions. It can be useful for a health authority that wants to consult the safety history of a specific device, check risks, the corrective actions taken, and other information about the device."""@en ;
                                                                         <http://purl.org/dc/terms/license> "https://creativecommons.org/licenses/by/4.0/"@en ;
                                                                         <http://purl.org/dc/terms/title> "Classification of medical devices and in vitro diagnostic devices according to the European MDR and IVDR regulations"@en ;
                                                                         <http://purl.org/vocab/vann/preferredNamespacePrefix> "mdr"@en ;
                                                                         <http://purl.org/vocab/vann/preferredNamespaceUri> "http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR/"@en ;
                                                                         owl:versionIRI "1.0"@en ;
                                                                         owl:versionInfo "v1.0"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/bibliographicCitation
<http://purl.org/dc/terms/bibliographicCitation> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#sameAs
rdfs:sameAs rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionIRI
owl:versionIRI rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#authorizedBy
:authorizedBy rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :CompetentAuthority ;
              rdfs:comment "Relation between a Manufacturer and the corresponding competent authority"@en ;
              rdfs:label "Authorized by"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasActionStatus
:hasActionStatus rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :CorrectiveAction ;
                 rdfs:range :ActionStatus ;
                 rdfs:comment "Status of a corrective aciton"@en ;
                 rdfs:label "Has action status?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasActionType
:hasActionType rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range :ActionType ;
               rdfs:comment "Type of corrective action applied"@en ;
               rdfs:label "Has action type?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasAffectedDeviceType
:hasAffectedDeviceType rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :Risk ;
                       rdfs:range :DeviceType ;
                       rdfs:comment "Type of affected device in a specific risk"@en ;
                       rdfs:label "Has affected device type?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasDevice
:hasDevice rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Incident ;
           rdfs:range :Device ;
           rdfs:comment "Relation between the incident and the medical device"@en ;
           rdfs:label "has device?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Device ;
               rdfs:range :DeviceType ;
               rdfs:comment "Type of medical device"@en ;
               rdfs:label "has device type?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasIncident
:hasIncident rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range :Incident ;
             rdfs:comment "Relation between the corrective action and its incident"@en ;
             rdfs:label "has incident?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasIncidentType
:hasIncidentType rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :IncidentType ;
                 rdfs:comment "Type of incident"@en ;
                 rdfs:label "has incident type?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Relation between a device and its incident"@en ;
                 rdfs:label "has manufacturer?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasRisk
:hasRisk rdf:type owl:ObjectProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Incident ;
         rdfs:range :Risk ;
         rdfs:comment "Relation between incident and a risk"@en ;
         rdfs:label "has risk?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasRiskCategory
:hasRiskCategory rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :RiskCategory ;
                 rdfs:comment "Relation between risk and its category"@en ;
                 rdfs:label "has risk category?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Relation between the device and its risk class (important)"@en ;
              rdfs:label "has risk class?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#hasRiskType
:hasRiskType rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Risk ;
             rdfs:range :RiskType ;
             rdfs:comment "Type of risks"@en ;
             rdfs:label "has risk type?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#reportingBy
:reportingBy rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Incident ;
             rdfs:range :Manufacturer ;
             rdfs:comment "Relation between incident and its manufacturer"@en ;
             rdfs:label "Reporting by"@en .


#################################################################
#    Data properties
#################################################################

###  http://schema.org/description
<http://schema.org/description> rdf:type owl:DatatypeProperty ;
                                rdfs:range xsd:string ;
                                rdfs:comment "It is a description to different stuff"@en ;
                                rdfs:label "Description"@en .


###  http://schema.org/email
<http://schema.org/email> rdf:type owl:DatatypeProperty ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Email of the manufacturer"@en ;
                          rdfs:label "Email"@en .


###  http://schema.org/location
<http://schema.org/location> rdf:type owl:DatatypeProperty ;
                             rdfs:range xsd:string ;
                             rdfs:comment "It refers to the affected countries or those reporting."@en ;
                             rdfs:label "Location"@en .


###  http://schema.org/name
<http://schema.org/name> rdf:type owl:DatatypeProperty ;
                         rdfs:range xsd:string ;
                         rdfs:comment "To name different stuff"@en ;
                         rdfs:label "Name"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#action_date
:action_date rdf:type owl:DatatypeProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:date ;
             rdfs:comment "The date when corrective action began"@en ;
             rdfs:label "Action date"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#authorization_number
:authorization_number rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Manufacturer ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Auth number of the manufacturer"@en ;
                      rdfs:label "Auth number"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#closure_date
:closure_date rdf:type owl:DatatypeProperty ;
              rdfs:domain :CorrectiveAction ;
              rdfs:range xsd:date ;
              rdfs:comment "The date when corretive actions end"@en ;
              rdfs:label "Closure date"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#corrective_action_taken
:corrective_action_taken rdf:type owl:DatatypeProperty ;
                         rdfs:domain :Incident ;
                         rdfs:range xsd:boolean ;
                         rdfs:comment """If for an incident, corrective actions was taken.
It can take value:true or false"""@en ;
                         rdfs:label "Corrective action taken"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#detection_date
:detection_date rdf:type owl:DatatypeProperty ;
                rdfs:domain :Incident ;
                rdfs:range xsd:date ;
                rdfs:comment "The date when incident was detected"@en ;
                rdfs:label "Detection date"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#devices_affected
:devices_affected rdf:type owl:DatatypeProperty ;
                  rdfs:domain :CorrectiveAction ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "Number of affected devices"@en ;
                  rdfs:label "Devices affected"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#eudamed_fsca_ref
:eudamed_fsca_ref rdf:type owl:DatatypeProperty ;
                  rdfs:domain :CorrectiveAction ;
                  rdfs:range xsd:string ;
                  rdfs:comment "EUDAMED FSCA reference"@en ;
                  rdfs:label "EUDAMED FSCA ref"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#eudamed_incident_ref
:eudamed_incident_ref rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Incident ;
                      rdfs:range xsd:string ;
                      rdfs:comment "EUDAMED incident reference"@en ;
                      rdfs:label "EUDAMED incident ref"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#eudamed_srn
:eudamed_srn rdf:type owl:DatatypeProperty ;
             rdfs:domain :Manufacturer ;
             rdfs:range xsd:string ;
             rdfs:comment "EUDAMED serial registration number"@en ;
             rdfs:label "EUDAMED SRN"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#event_date
:event_date rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "The date when incident happened"@en ;
            rdfs:label "Event date"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#imdrf_code
:imdrf_code rdf:type owl:DatatypeProperty ;
            rdfs:domain :Risk ;
            rdfs:range xsd:string ;
            rdfs:comment "IMDRF code"@en ;
            rdfs:label "IMDRF"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#intended_purpose
:intended_purpose rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Device ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Intented purpose of a medical device"@en ;
                  rdfs:label "Intended purpose"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#is_active
:is_active rdf:type owl:DatatypeProperty ;
           rdfs:domain :Device ;
           rdfs:range xsd:boolean ;
           rdfs:comment "True if the medical is active, false if it is not."@en ;
           rdfs:label "Is active?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#is_implantable
:is_implantable rdf:type owl:DatatypeProperty ;
                rdfs:domain :Device ;
                rdfs:range xsd:boolean ;
                rdfs:comment "True if the medical is implantable, false if it is not."@en ;
                rdfs:label "Is implantable?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#is_ivd
:is_ivd rdf:type owl:DatatypeProperty ;
        rdfs:domain :Device ;
        rdfs:range xsd:boolean ;
        rdfs:comment "True if the medical is ivd, false if it is not."@en ;
        rdfs:label "Is ivd?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#is_reusable
:is_reusable rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:boolean ;
             rdfs:comment "True if the medical is reusable, false if it is not."@en ;
             rdfs:label "Is reusable?"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#outcome
:outcome rdf:type owl:DatatypeProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "Impact of the incident"@en ;
         rdfs:label "Outcome"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#patient_age
:patient_age rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:integer ;
             rdfs:comment "Age of the registered patient"@en ;
             rdfs:label "Patient age"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#patient_sex
:patient_sex rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:string ;
             rdfs:comment "Gender of the registered patient"@en ;
             rdfs:label "Patient sex"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#probability
:probability rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "It can take the next values: high, medium or low"@en ;
             rdfs:label "Probability"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#regulatory_framework
:regulatory_framework rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Device ;
                      rdfs:range xsd:string ;
                      rdfs:comment "MDR or IVDR, depending on the type of device"@en ;
                      rdfs:label "Regulatory framework"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#report_date
:report_date rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:date ;
             rdfs:comment "Report date of an incident"@en ;
             rdfs:label "Report date"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#scope
:scope rdf:type owl:DatatypeProperty ;
       rdfs:domain :CorrectiveAction ;
       rdfs:range xsd:string ;
       rdfs:comment "Actions taken to eliminate the root cause of the incident"@en ;
       rdfs:label "Scope"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#severity
:severity rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment """Level of severity of a risk. 
Values: critical, serious, moderate."""@en ;
          rdfs:label "Severity"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#udi_di
:udi_di rdf:type owl:DatatypeProperty ;
        rdfs:domain :Device ;
        rdfs:range xsd:string ;
        rdfs:comment "Identifier of medical devices"@en ;
        rdfs:label "UDI-DI"@en .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#AFMPS
:AFMPS rdf:type owl:Class ;
       rdfs:subClassOf :CompetentAuthority ;
       owl:disjointWith :ANSM ,
                        :BfArM ,
                        :HPRA ,
                        :MHRA ,
                        :MPA ,
                        :RIVM ,
                        :Swissmedic ;
       rdfs:comment "Agence Fédérale des Médicaments et des Produits de Santé"@fr ;
       rdfs:label "AFMPS" .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ANSM
:ANSM rdf:type owl:Class ;
      rdfs:subClassOf :CompetentAuthority ;
      owl:disjointWith :BfArM ,
                       :HPRA ,
                       :MHRA ,
                       :MPA ,
                       :RIVM ,
                       :Swissmedic ;
      rdfs:comment "Agence Nationale de Sécurité du Médicament et des Produits de Santé"@fr-be ;
      rdfs:label "ANSM" .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ActionStatus
:ActionStatus rdf:type owl:Class ;
              rdfs:comment "Corrective action status"@en ;
              rdfs:label "Action status"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ActionType
:ActionType rdf:type owl:Class ;
            rdfs:comment "Type of corrective action"@en ;
            rdfs:label "Action type"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Active
:Active rdf:type owl:Class ;
        rdfs:subClassOf :DeviceType ;
        owl:disjointWith :ActiveImplant ,
                         :Implantable ,
                         :ImplantableActive ,
                         :InVitroDiagnostic ,
                         :SelfTest ,
                         :SingleUse ;
        rdfs:comment "It is any medical device that relies on a source of energy other than that generated directly by the human body or gravity." ;
        rdfs:label "Active"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :DeviceType ;
               owl:disjointWith :Implantable ,
                                :ImplantableActive ,
                                :InVitroDiagnostic ,
                                :SelfTest ,
                                :SingleUse ;
               rdfs:comment "Any device relying on a power source other than human energy or gravity, intended to be totally or partially introduced into the body (or replacing an eye surface) via clinical intervention and intended to remain after the procedure"@en ;
               rdfs:label "Active implant"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#BfArM
:BfArM rdf:type owl:Class ;
       rdfs:subClassOf :CompetentAuthority ;
       owl:disjointWith :HPRA ,
                        :MHRA ,
                        :MPA ,
                        :RIVM ,
                        :Swissmedic ;
       rdfs:comment "Bundesinstitut für Arzneimittel und Medizinprodukte"@de ;
       rdfs:label "BfArM" .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ClassI
:ClassI rdf:type owl:Class ;
        rdfs:subClassOf :RiskClass ;
        owl:disjointWith :ClassIII ,
                         :ClassIIa ,
                         :ClassIIb ;
        rdfs:comment "Devices with minimal risk to patient safety, such as non-electronic walking aids, bandages, or simple surgical instruments."@en ;
        rdfs:label "Class I"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          owl:disjointWith :ClassIIa ,
                           :ClassIIb ;
          rdfs:comment "Devices with the highest risk profile, which are vital for supporting life, have direct contact with the heart/central circulatory system, or are permanently implanted, such as cardiac pacemakers, heart valves, and breast implants."@en ;
          rdfs:label "Class III"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          owl:disjointWith :ClassIIb ;
          rdfs:comment "Devices with a moderate risk level, often used for short-term, non-critical, or diagnostic purposes, such as hearing aids, ultrasound equipment, or standard catheters."@en ;
          rdfs:label "Class IIa"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :RiskClass ;
          rdfs:comment "Devices that pose significant risk, often including active devices meant for monitoring or administering substances, or long-term implants, such as ventilators, infusion pumps, or bone fixation devices."@en ;
          rdfs:label "Class IIb"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Closed
:Closed rdf:type owl:Class ;
        rdfs:subClassOf :ActionStatus ;
        owl:disjointWith :Open ;
        rdfs:comment "Corrective Action is closed"@en ;
        rdfs:label "Closed"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:comment "Class of Competent Authorities"@en ;
                    rdfs:label "Competent authority"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Contamination
:Contamination rdf:type owl:Class ;
               rdfs:subClassOf :RiskType ;
               owl:disjointWith :Cybersecurity ,
                                :Diagnostic ,
                                :Infection ,
                                :Injury ,
                                :Interference ,
                                :Malfunction ,
                                :Material ,
                                :Radiation ,
                                :Software ;
               rdfs:comment "Risks caused by contamination"@en ;
               rdfs:label "Contamination"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasActionStatus ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :ActionStatus
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasActionType ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :ActionType
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasIncident ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :Incident
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :closure_date ;
                                    owl:allValuesFrom xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://schema.org/description> ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :action_date ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :devices_affected ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:integer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :eudamed_fsca_ref ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :scope ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ;
                  rdfs:comment "Class of Corrective Action"@en ;
                  rdfs:label "Corrective action"@en ;
                  rdfs:sameAs "http://dbpedia.org/resource/Corrective_and_preventive_action"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Cybersecurity
:Cybersecurity rdf:type owl:Class ;
               rdfs:subClassOf :RiskType ;
               owl:disjointWith :Diagnostic ,
                                :Infection ,
                                :Injury ,
                                :Interference ,
                                :Malfunction ,
                                :Material ,
                                :Radiation ,
                                :Software ;
               rdfs:comment "Risks caused by cybersecurity"@en ;
               rdfs:label "Cybersecurity"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasDeviceType ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :DeviceType
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Manufacturer
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasRiskClass ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :RiskClass
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty <http://schema.org/name> ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :intended_purpose ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_active ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_implantable ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_ivd ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_reusable ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :regulatory_framework ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ;
        rdfs:comment "Class of medical device"@en ;
        rdfs:label "Medical device"@en ;
        rdfs:sameAs "http://dbpedia.org/resource/Medical_device"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#DeviceFailure
:DeviceFailure rdf:type owl:Class ;
               rdfs:subClassOf :RiskCategory ;
               owl:disjointWith :DevicePerformance ,
                                :DeviceSafety ,
                                :DiagnosticError ,
                                :PatientHarm ,
                                :ProductQuality ;
               rdfs:comment "Risk caused by a device failure"@en ;
               rdfs:label "Device failure"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#DevicePerformance
:DevicePerformance rdf:type owl:Class ;
                   rdfs:subClassOf :RiskCategory ;
                   owl:disjointWith :DeviceSafety ,
                                    :DiagnosticError ,
                                    :PatientHarm ,
                                    :ProductQuality ;
                   rdfs:comment "Risk related to device performance"@en ;
                   rdfs:label "Device performance"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#DeviceSafety
:DeviceSafety rdf:type owl:Class ;
              rdfs:subClassOf :RiskCategory ;
              owl:disjointWith :DiagnosticError ,
                               :PatientHarm ;
              rdfs:comment "Risk related to device security"@en ;
              rdfs:label "Device safety"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:comment "Type of medical device"@en ;
            rdfs:label "Device type"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Diagnostic
:Diagnostic rdf:type owl:Class ;
            rdfs:subClassOf :RiskType ;
            owl:disjointWith :Infection ,
                             :Injury ,
                             :Interference ,
                             :Malfunction ,
                             :Material ,
                             :Radiation ,
                             :Software ;
            rdfs:comment "Risks associated with the diagnostic"@en ;
            rdfs:label "Diagnostic"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#DiagnosticError
:DiagnosticError rdf:type owl:Class ;
                 rdfs:subClassOf :RiskCategory ;
                 owl:disjointWith :PatientHarm ,
                                  :ProductQuality ;
                 rdfs:comment "Risk associated with diagnostic error"@en ;
                 rdfs:label "Diagnostic error"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#HPRA
:HPRA rdf:type owl:Class ;
      rdfs:subClassOf :CompetentAuthority ;
      owl:disjointWith :MHRA ,
                       :MPA ,
                       :RIVM ,
                       :Swissmedic ;
      rdfs:comment "Health Products Regulatory Authority"@en ;
      rdfs:label "HPRA" .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Implantable
:Implantable rdf:type owl:Class ;
             rdfs:subClassOf :DeviceType ;
             owl:disjointWith :ImplantableActive ,
                              :InVitroDiagnostic ,
                              :SelfTest ,
                              :SingleUse ;
             rdfs:comment "Any device, including partially or wholly absorbed ones, intended to be totally introduced into the human body, or to replace an epithelial/eye surface, via clinical intervention and remain there after the procedure."@en ;
             rdfs:label "Implantable"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ImplantableActive
:ImplantableActive rdf:type owl:Class ;
                   rdfs:subClassOf :DeviceType ;
                   owl:disjointWith :InVitroDiagnostic ,
                                    :SelfTest ,
                                    :SingleUse ;
                   rdfs:comment "A powered device introduced totally or partially into the body via surgery or medical intervention (including natural orifices) and intended to remain there after the procedure."@en ;
                   rdfs:label "Implantable active"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#InSitu
:InSitu rdf:type owl:Class ;
        rdfs:subClassOf :ActionType ;
        owl:disjointWith :Recall ,
                         :SafetyAlert ,
                         :UserNotice ;
        rdfs:comment "An action taken to address a product problem while the device remains at the healthcare facility or user location"@en ;
        rdfs:label "In Situ"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#InVitroDiagnostic
:InVitroDiagnostic rdf:type owl:Class ;
                   rdfs:subClassOf :DeviceType ;
                   owl:disjointWith :SelfTest ,
                                    :SingleUse ;
                   rdfs:comment "Any reagent, instrument, software, or kit used in vitro to examine specimens from the human body, such as blood or tissue, to provide information on health status, illnesses, or congenital impairments."@en ;
                   rdfs:label "In vitro diagnostic"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :hasDevice ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Device
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasIncidentType ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :IncidentType
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasRisk ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Risk
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reportingBy ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Manufacturer
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty <http://schema.org/location> ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :corrective_action_taken ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:boolean
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :detection_date ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :eudamed_incident_ref ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :event_date ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :outcome ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :patient_age ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:integer
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :patient_sex ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :report_date ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ;
          rdfs:comment "Class of incident"@en ;
          rdfs:label "Incident"@en ;
          rdfs:sameAs "http://dbpedia.org/resource/Adverse_effect"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:comment "Type of incident"@en ;
              rdfs:label "Incident type"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Infection
:Infection rdf:type owl:Class ;
           rdfs:subClassOf :RiskType ;
           owl:disjointWith :Injury ,
                            :Interference ,
                            :Malfunction ,
                            :Material ,
                            :Radiation ,
                            :Software ;
           rdfs:comment "Risks caused by an infection"@en ;
           rdfs:label "Infection"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Injury
:Injury rdf:type owl:Class ;
        rdfs:subClassOf :RiskType ;
        owl:disjointWith :Interference ,
                         :Malfunction ,
                         :Material ,
                         :Radiation ,
                         :Software ;
        rdfs:comment "Risks caused by an injury"@en ;
        rdfs:label "Injury"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Interference
:Interference rdf:type owl:Class ;
              rdfs:subClassOf :RiskType ;
              owl:disjointWith :Malfunction ,
                               :Material ,
                               :Radiation ,
                               :Software ;
              rdfs:comment "Risks caused by interference"@en ;
              rdfs:label "Interference"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#MHRA
:MHRA rdf:type owl:Class ;
      rdfs:subClassOf :CompetentAuthority ;
      owl:disjointWith :MPA ,
                       :RIVM ,
                       :Swissmedic ;
      rdfs:comment "Medicines and Healthcare products Regulatory Agency"@en ;
      rdfs:label "MHRA" .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#MPA
:MPA rdf:type owl:Class ;
     rdfs:subClassOf :CompetentAuthority ;
     owl:disjointWith :RIVM ,
                      :Swissmedic ;
     rdfs:comment "Medical Products Agency"@en ;
     rdfs:label "MPA" .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Malfunction
:Malfunction rdf:type owl:Class ;
             rdfs:subClassOf :RiskType ;
             owl:disjointWith :Material ,
                              :Radiation ,
                              :Software ;
             rdfs:comment "Risks caused by a malfunction"@en ;
             rdfs:label "Malfunction"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :authorizedBy ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :CompetentAuthority
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <http://schema.org/email> ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <http://schema.org/location> ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <http://schema.org/name> ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :authorization_number ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :eudamed_srn ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:comment "Class of manufacturer"@en ;
              rdfs:label "Manufacturer"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Material
:Material rdf:type owl:Class ;
          rdfs:subClassOf :RiskType ;
          owl:disjointWith :Radiation ,
                           :Software ;
          rdfs:comment "Risks caused by material"@en ;
          rdfs:label "Material"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#NearMiss
:NearMiss rdf:type owl:Class ;
          rdfs:subClassOf :IncidentType ;
          owl:disjointWith :Serious ;
          rdfs:comment "It is an unplanned event that had the potential to cause, but did not result in, patient harm, injury, or damage, often due to luck or timely interception"@en ;
          rdfs:label "Near miss"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Open
:Open rdf:type owl:Class ;
      rdfs:subClassOf :ActionStatus ;
      rdfs:comment "Corrective action is open"@en ;
      rdfs:label "Open"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#PatientHarm
:PatientHarm rdf:type owl:Class ;
             rdfs:subClassOf :RiskCategory ;
             owl:disjointWith :ProductQuality ;
             rdfs:comment "Risk that could cause harm to the patient"@en ;
             rdfs:label "Patient harm"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#ProductQuality
:ProductQuality rdf:type owl:Class ;
                rdfs:subClassOf :RiskCategory ;
                rdfs:comment "Risk related to a decline in the device's quality"@en ;
                rdfs:label "Product quality"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#RIVM
:RIVM rdf:type owl:Class ;
      rdfs:subClassOf :CompetentAuthority ;
      owl:disjointWith :Swissmedic ;
      rdfs:comment "Rijksinstituut voor Volksgezondheid en Milieu"@de ;
      rdfs:label "RIVM" .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Radiation
:Radiation rdf:type owl:Class ;
           rdfs:subClassOf :RiskType ;
           owl:disjointWith :Software ;
           rdfs:comment "Risks caused by a radiation"@en ;
           rdfs:label "Radiation"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :ActionType ;
        owl:disjointWith :SafetyAlert ,
                         :UserNotice ;
        rdfs:comment "It is a manufacturer’s action to fix, return, or destroy a medical device after it has left their control due to risks to safety, performance, or regulatory compliance"@en ;
        rdfs:label "Recall"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :hasAffectedDeviceType ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :DeviceType
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasRiskCategory ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :RiskCategory
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasRiskType ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :RiskType
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty <http://schema.org/description> ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty <http://schema.org/name> ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :imdrf_code ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :probability ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :severity ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ;
      rdfs:comment "Class of risk"@en ;
      rdfs:label "Risk"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:comment "Risk category class"@en ;
              rdfs:label "Risk category"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "Class of risk by MDR"@en ;
           rdfs:label "Risk class"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#RiskType
:RiskType rdf:type owl:Class ;
          rdfs:comment "Risk type class"@en ;
          rdfs:label "Risk type"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :ActionType ;
             owl:disjointWith :UserNotice ;
             rdfs:comment "It is a mandatory communication sent by a medical device manufacturer to users (hospitals, doctors, patients) to prevent or reduce the risk of a serious incident with a device that is already on the market" ;
             rdfs:label "Safety alert"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#SelfTest
:SelfTest rdf:type owl:Class ;
          rdfs:subClassOf :DeviceType ;
          owl:disjointWith :SingleUse ;
          rdfs:comment "It is an in vitro diagnostic medical device intended by the manufacturer for use by laypersons in a home environment."@en ;
          rdfs:label "Self test"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Serious
:Serious rdf:type owl:Class ;
         rdfs:subClassOf :IncidentType ;
         rdfs:comment "It is defined as any incident involving a device that directly or indirectly led, might have led, or might lead to the death of a patient/user, a serious deterioration in health (temporary/permanent), or a serious public health threat. It includes malfunctions, performance issues, and use errors."@en ;
         rdfs:label "Serious"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#SingleUse
:SingleUse rdf:type owl:Class ;
           rdfs:subClassOf :DeviceType ;
           rdfs:comment "It is defined as a device intended to be used on one individual patient during a single procedure and then discarded. They are not intended to be reprocessed or reused."@en ;
           rdfs:label "Single use"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Software
:Software rdf:type owl:Class ;
          rdfs:subClassOf :RiskType ;
          rdfs:comment "Risks caused by software"@en ;
          rdfs:label "Software"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#Swissmedic
:Swissmedic rdf:type owl:Class ;
            rdfs:subClassOf :CompetentAuthority ;
            rdfs:comment "Swiss authority"@en ;
            rdfs:label "Swissmedic"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :ActionType ;
            rdfs:comment "It is an official communication from a manufacturer to users informing them of a safety risk with a medical device and providing instructions to prevent harm."@en ;
            rdfs:label "User notice"@en .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/bea/ontologies/2026/clasification_MDR_IVDR#DEV-001
:DEV-001 rdf:type owl:NamedIndividual ,
                  :Device ,
                  [ rdf:type owl:Restriction ;
                    owl:onProperty :hasDeviceType ;
                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onClass :ImplantableActive
