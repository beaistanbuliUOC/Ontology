###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DEV-001
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DEV-001> rdf:type owl:NamedIndividual ,
                                                                                          <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device> ,
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasDeviceType> ;
                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                            owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive>
                                                                                          ] ,
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskClass> ;
                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                            owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIII>
                                                                                          ] ;
                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasManufacturer> <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MAN-001> ;
                                                                                 <http://schema.org/name> "HeartMate 3 LVAD" ;
                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#intended_purpose> "Ventricular assist device for end-stage heart failure" ;
                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_active> "true"^^xsd:boolean ;
                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_implantable> "true"^^xsd:boolean ;
                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_ivd> "false"^^xsd:boolean ;
                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#is_reusable> "false"^^xsd:boolean ;
                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#regulatory_framework> "MDR" ;
                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#udi_di> "(01)00380740009095" ;
                                                                                 rdfs:comment "First device classfied"@en ;
                                                                                 rdfs:label "Device 1"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#FSCA-001
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#FSCA-001> rdf:type owl:NamedIndividual ,
                                                                                           <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction> ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasActionStatus> ;
                                                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                             owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Open>
                                                                                           ] ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasActionType> ;
                                                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                             owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SafetyAlert>
                                                                                           ] ;
                                                                                  <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasIncident> <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#INC-001> ;
                                                                                  <http://schema.org/description> "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0â€“3.0" ;
                                                                                  <http://schema.org/location> "EU-wide" ;
                                                                                  <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#action_date> "2024-02-01"^^xsd:date ;
                                                                                  <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#devices_affected> 850 ;
                                                                                  <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#eudamed_fsca_ref> "EU-FSCA-2024-000001" ;
                                                                                  <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#scope> "All HeartMate 3 LVAD units implanted since 2020" ;
                                                                                  rdfs:comment "First corrective action"@en ;
                                                                                  rdfs:label "Corrective action 1"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#INC-001
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#INC-001> rdf:type owl:NamedIndividual ,
                                                                                          <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident> ,
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasIncidentType> ;
                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                            owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Serious>
                                                                                          ] ;
