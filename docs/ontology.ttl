                                                                                                            <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest> ,
                                                                                                            <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse> ;
                                                                                           rdfs:comment "A powered device introduced totally or partially into the body via surgery or medical intervention (including natural orifices) and intended to remain there after the procedure."@en ;
                                                                                           rdfs:label "Implantable active"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InSitu
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InSitu> rdf:type owl:Class ;
