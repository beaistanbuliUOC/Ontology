                                                                                   rdfs:comment "Risks caused by a radiation"@en ;
                                                                                   rdfs:label "Radiation"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Recall
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Recall> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType> ;
                                                                                owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SafetyAlert> ,
                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#UserNotice> ;
                                                                                rdfs:comment "It is a manufacturer’s action to fix, return, or destroy a medical device after it has left their control due to risks to safety, performance, or regulatory compliance"@en ;
                                                                                rdfs:label "Recall"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk> rdf:type owl:Class ;
                                                                              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasAffectedDeviceType> ;
                                                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType>
                                                                                              ] ,
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskCategory> ;
                                                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskCategory>
                                                                                              ] ,
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasRiskType> ;
                                                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType>
                                                                                              ] ,
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://schema.org/description> ;
                                                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                owl:onDataRange xsd:string
                                                                                              ] ,
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://schema.org/name> ;
                                                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                owl:onDataRange xsd:string
                                                                                              ] ,
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#imdrf_code> ;
                                                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                owl:onDataRange xsd:string
                                                                                              ] ,
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#probability> ;
                                                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                owl:onDataRange xsd:string
                                                                                              ] ,
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#severity> ;
                                                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                owl:onDataRange xsd:string
                                                                                              ] ;
                                                                              rdfs:comment "Class of risk"@en ;
                                                                              rdfs:label "Risk"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskCategory
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskCategory> rdf:type owl:Class ;
                                                                                      rdfs:comment "Risk category class"@en ;
                                                                                      rdfs:label "Risk category"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass> rdf:type owl:Class ;
                                                                                   rdfs:comment "Class of risk by MDR"@en ;
                                                                                   rdfs:label "Risk class"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType> rdf:type owl:Class ;
                                                                                  rdfs:comment "Risk type class"@en ;
                                                                                  rdfs:label "Risk type"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SafetyAlert
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SafetyAlert> rdf:type owl:Class ;
                                                                                     rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType> ;
                                                                                     owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#UserNotice> ;
                                                                                     rdfs:comment "It is a mandatory communication sent by a medical device manufacturer to users (hospitals, doctors, patients) to prevent or reduce the risk of a serious incident with a device that is already on the market" ;
                                                                                     rdfs:label "Safety alert"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType> ;
                                                                                  owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse> ;
                                                                                  rdfs:comment "It is an in vitro diagnostic medical device intended by the manufacturer for use by laypersons in a home environment."@en ;
                                                                                  rdfs:label "Self test"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Serious
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Serious> rdf:type owl:Class ;
                                                                                 rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#IncidentType> ;
                                                                                 rdfs:comment "It is defined as any incident involving a device that directly or indirectly led, might have led, or might lead to the death of a patient/user, a serious deterioration in health (temporary/permanent), or a serious public health threat. It includes malfunctions, performance issues, and use errors."@en ;
                                                                                 rdfs:label "Serious"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType> ;
                                                                                   rdfs:comment "It is defined as a device intended to be used on one individual patient during a single procedure and then discarded. They are not intended to be reprocessed or reused."@en ;
                                                                                   rdfs:label "Single use"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Software
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Software> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType> ;
                                                                                  rdfs:comment "Risks caused by software"@en ;
                                                                                  rdfs:label "Software"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority> ;
                                                                                    rdfs:comment "Swiss authority"@en ;
                                                                                    rdfs:label "Swissmedic"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#UserNotice
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#UserNotice> rdf:type owl:Class ;
                                                                                    rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType> ;
                                                                                    rdfs:comment "It is an official communication from a manufacturer to users informing them of a safety risk with a medical device and providing instructions to prevent harm."@en ;
                                                                                    rdfs:label "User notice"@en .


