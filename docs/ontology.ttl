###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#outcome
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#outcome> rdf:type owl:DatatypeProperty ;
                                                                                 rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident> ;
                                                                                 rdfs:range xsd:string ;
                                                                                 rdfs:comment "Impact of the incident"@en ;
                                                                                 rdfs:label "Outcome"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#patient_age
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#patient_age> rdf:type owl:DatatypeProperty ;
                                                                                     rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident> ;
                                                                                     rdfs:range xsd:integer ;
                                                                                     rdfs:comment "Age of the registered patient"@en ;
                                                                                     rdfs:label "Patient age"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#patient_sex
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#patient_sex> rdf:type owl:DatatypeProperty ;
                                                                                     rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident> ;
                                                                                     rdfs:range xsd:string ;
                                                                                     rdfs:comment "Gender of the registered patient"@en ;
                                                                                     rdfs:label "Patient sex"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#probability
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#probability> rdf:type owl:DatatypeProperty ;
                                                                                     rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk> ;
                                                                                     rdfs:range xsd:string ;
                                                                                     rdfs:comment "It can take the next values: high, medium or low"@en ;
                                                                                     rdfs:label "Probability"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#regulatory_framework
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#regulatory_framework> rdf:type owl:DatatypeProperty ;
                                                                                              rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device> ;
                                                                                              rdfs:range xsd:string ;
                                                                                              rdfs:comment "MDR or IVDR, depending on the type of device"@en ;
                                                                                              rdfs:label "Regulatory framework"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#report_date
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#report_date> rdf:type owl:DatatypeProperty ;
                                                                                     rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident> ;
                                                                                     rdfs:range xsd:date ;
                                                                                     rdfs:comment "Report date of an incident"@en ;
                                                                                     rdfs:label "Report date"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#scope
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#scope> rdf:type owl:DatatypeProperty ;
                                                                               rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction> ;
                                                                               rdfs:range xsd:string ;
                                                                               rdfs:comment "Actions taken to eliminate the root cause of the incident"@en ;
                                                                               rdfs:label "Scope"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#severity
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#severity> rdf:type owl:DatatypeProperty ;
                                                                                  rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Risk> ;
                                                                                  rdfs:range xsd:string ;
                                                                                  rdfs:comment """Level of severity of a risk. 
Values: critical, serious, moderate."""@en ;
                                                                                  rdfs:label "Severity"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#udi_di
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#udi_di> rdf:type owl:DatatypeProperty ;
                                                                                rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device> ;
                                                                                rdfs:range xsd:string ;
                                                                                rdfs:comment "Identifier of medical devices"@en ;
                                                                                rdfs:label "UDI-DI"@en .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#AFMPS
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#AFMPS> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority> ;
                                                                               owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ANSM> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#BfArM> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#HPRA> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MHRA> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MPA> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RIVM> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic> ;
                                                                               rdfs:comment "Agence Fédérale des Médicaments et des Produits de Santé"@fr ;
                                                                               rdfs:label "AFMPS" .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ANSM
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ANSM> rdf:type owl:Class ;
                                                                              rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority> ;
                                                                              owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#BfArM> ,
                                                                                               <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#HPRA> ,
                                                                                               <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MHRA> ,
                                                                                               <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MPA> ,
                                                                                               <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RIVM> ,
                                                                                               <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic> ;
                                                                              rdfs:comment "Agence Nationale de Sécurité du Médicament et des Produits de Santé"@fr-be ;
                                                                              rdfs:label "ANSM" .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus> rdf:type owl:Class ;
                                                                                      rdfs:comment "Corrective action status"@en ;
                                                                                      rdfs:label "Action status"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType> rdf:type owl:Class ;
                                                                                    rdfs:comment "Type of corrective action"@en ;
                                                                                    rdfs:label "Action type"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Active
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Active> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType> ;
                                                                                owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActiveImplant> ,
                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Implantable> ,
                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive> ,
                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InVitroDiagnostic> ,
                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest> ,
                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse> ;
                                                                                rdfs:comment "It is any medical device that relies on a source of energy other than that generated directly by the human body or gravity." ;
                                                                                rdfs:label "Active"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActiveImplant
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActiveImplant> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType> ;
                                                                                       owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Implantable> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InVitroDiagnostic> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse> ;
                                                                                       rdfs:comment "Any device relying on a power source other than human energy or gravity, intended to be totally or partially introduced into the body (or replacing an eye surface) via clinical intervention and intended to remain after the procedure"@en ;
                                                                                       rdfs:label "Active implant"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#BfArM
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#BfArM> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority> ;
                                                                               owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#HPRA> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MHRA> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#MPA> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RIVM> ,
                                                                                                <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Swissmedic> ;
                                                                               rdfs:comment "Bundesinstitut für Arzneimittel und Medizinprodukte"@de ;
                                                                               rdfs:label "BfArM" .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassI
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassI> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass> ;
                                                                                owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIII> ,
                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIa> ,
                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb> ;
                                                                                rdfs:comment "Devices with minimal risk to patient safety, such as non-electronic walking aids, bandages, or simple surgical instruments."@en ;
                                                                                rdfs:label "Class I"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIII
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIII> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass> ;
                                                                                  owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIa> ,
                                                                                                   <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb> ;
                                                                                  rdfs:comment "Devices with the highest risk profile, which are vital for supporting life, have direct contact with the heart/central circulatory system, or are permanently implanted, such as cardiac pacemakers, heart valves, and breast implants."@en ;
                                                                                  rdfs:label "Class III"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIa
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIa> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass> ;
                                                                                  owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb> ;
                                                                                  rdfs:comment "Devices with a moderate risk level, often used for short-term, non-critical, or diagnostic purposes, such as hearing aids, ultrasound equipment, or standard catheters."@en ;
                                                                                  rdfs:label "Class IIa"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ClassIIb> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskClass> ;
                                                                                  rdfs:comment "Devices that pose significant risk, often including active devices meant for monitoring or administering substances, or long-term implants, such as ventilators, infusion pumps, or bone fixation devices."@en ;
                                                                                  rdfs:label "Class IIb"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Closed
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Closed> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus> ;
                                                                                owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Open> ;
                                                                                rdfs:comment "Corrective Action is closed"@en ;
                                                                                rdfs:label "Closed"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CompetentAuthority> rdf:type owl:Class ;
                                                                                            rdfs:comment "Class of Competent Authorities"@en ;
                                                                                            rdfs:label "Competent authority"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Contamination
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Contamination> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType> ;
                                                                                       owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Cybersecurity> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Diagnostic> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Infection> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Injury> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Interference> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Malfunction> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Material> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Radiation> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Software> ;
                                                                                       rdfs:comment "Risks caused by contamination"@en ;
                                                                                       rdfs:label "Contamination"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#CorrectiveAction> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasActionStatus> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus>
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasActionType> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionType>
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasIncident> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onClass <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Incident>
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#closure_date> ;
                                                                                                            owl:allValuesFrom xsd:date
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://schema.org/description> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onDataRange xsd:string
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://schema.org/location> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onDataRange xsd:string
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#action_date> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onDataRange xsd:date
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#devices_affected> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onDataRange xsd:integer
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#eudamed_fsca_ref> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onDataRange xsd:string
                                                                                                          ] ,
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#scope> ;
                                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                            owl:onDataRange xsd:string
                                                                                                          ] ;
                                                                                          rdfs:comment "Class of Corrective Action"@en ;
                                                                                          rdfs:label "Corrective action"@en ;
                                                                                          rdfs:sameAs "http://dbpedia.org/resource/Corrective_and_preventive_action"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Cybersecurity
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Cybersecurity> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskType> ;
                                                                                       owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Diagnostic> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Infection> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Injury> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Interference> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Malfunction> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Material> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Radiation> ,
                                                                                                        <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Software> ;
                                                                                       rdfs:comment "Risks caused by cybersecurity"@en ;
                                                                                       rdfs:label "Cybersecurity"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Device> rdf:type owl:Class ;
                                                                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#hasDeviceType> ;
                                                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
