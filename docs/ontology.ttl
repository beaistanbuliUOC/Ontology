#################################################################
#    Data properties
#################################################################

###  http://schema.org/description
<http://schema.org/description> rdf:type owl:DatatypeProperty ;
                                rdfs:domain [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://schema.org/description> ;
                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ;
                                rdfs:range xsd:string ;
                                rdfs:label "Description" .


###  http://schema.org/email
<http://schema.org/email> rdf:type owl:DatatypeProperty ;
                          rdfs:domain <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Manufacturer> ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty <http://schema.org/email> ;
                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                        owl:onDataRange xsd:string
                                      ] ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Email of the manufacturer" ;
                          rdfs:label "email" .


###  http://schema.org/location
<http://schema.org/location> rdf:type owl:DatatypeProperty ;
                             rdfs:domain [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://schema.org/location> ;
                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                           owl:onDataRange xsd:string
                                         ] ;
                             rdfs:range xsd:string ;
                             rdfs:label "Location" .


###  http://schema.org/name
<http://schema.org/name> rdf:type owl:DatatypeProperty ;
                         rdfs:domain [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://schema.org/name> ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onDataRange xsd:string
                                     ] ;
                         rdfs:range xsd:string ;
                         rdfs:label "Name" .


