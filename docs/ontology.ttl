                                                                                                   owl:onDataRange xsd:date
                                                                                                 ] ;
                                                                                     rdfs:range xsd:date ;
                                                                                     rdfs:comment "The date when corrective action began" ;
                                                                                     rdfs:label "Action date" .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#authorization_number
