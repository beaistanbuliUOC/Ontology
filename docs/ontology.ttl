                                                                                                    owl:onProperty <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#closure_date> ;
                                                                                                    owl:allValuesFrom xsd:date
                                                                                                  ] ;
                                                                                      rdfs:range xsd:date ;
                                                                                      rdfs:comment "The date when corretive actions end" ;
                                                                                      rdfs:label "Closure date" .


