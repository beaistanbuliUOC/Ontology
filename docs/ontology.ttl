                                                                                                   <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Software> ;
                                                                                  rdfs:comment "Risks caused by material"@en ;
                                                                                  rdfs:label "Material"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#NearMiss
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#NearMiss> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#IncidentType> ;
                                                                                  owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Serious> ;
                                                                                  rdfs:comment "It is an unplanned event that had the potential to cause, but did not result in, patient harm, injury, or damage, often due to luck or timely interception"@en ;
                                                                                  rdfs:label "Near miss"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Open
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Open> rdf:type owl:Class ;
                                                                              rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ActionStatus> ;
                                                                              rdfs:comment "Corrective action is open"@en ;
                                                                              rdfs:label "Open"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#PatientHarm
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#PatientHarm> rdf:type owl:Class ;
                                                                                     rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskCategory> ;
                                                                                     owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ProductQuality> ;
                                                                                     rdfs:comment "Risk that could cause harm to the patient"@en ;
                                                                                     rdfs:label "Patient harm"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ProductQuality
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ProductQuality> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#RiskCategory> ;
                                                                                        rdfs:comment "Risk related to a decline in the device's quality"@en ;
                                                                                        rdfs:label "Product quality"@en .


