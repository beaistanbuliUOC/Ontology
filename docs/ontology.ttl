                                                                                                 <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#UserNotice> ;
                                                                                rdfs:comment "An action taken to address a product problem while the device remains at the healthcare facility or user location"@en ;
                                                                                rdfs:label "In Situ"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InVitroDiagnostic
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InVitroDiagnostic> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType> ;
