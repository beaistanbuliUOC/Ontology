###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Implantable
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#Implantable> rdf:type owl:Class ;
                                                                                     rdfs:subClassOf <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#DeviceType> ;
                                                                                     owl:disjointWith <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive> ,
                                                                                                      <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#InVitroDiagnostic> ,
                                                                                                      <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SelfTest> ,
                                                                                                      <http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#SingleUse> ;
                                                                                     rdfs:comment "Any device, including partially or wholly absorbed ones, intended to be totally introduced into the human body, or to replace an epithelial/eye surface, via clinical intervention and remain there after the procedure."@en ;
                                                                                     rdfs:label "Implantable"@en .


###  http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive
<http://www.semanticweb.org/bea/ontologies/2026/3clasificacion_MDR_IVDR#ImplantableActive> rdf:type owl:Class ;
